# ============================================================
# Gamaliel AI Pastor - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Get these from: https://supabase.com > Project > Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# LLM / AI PROVIDER
# Supports any OpenAI-compatible API (OpenAI, Groq, Together, etc.)
# For OpenAI: LLM_API_BASE_URL=https://api.openai.com/v1
# For Groq:   LLM_API_BASE_URL=https://api.groq.com/openai/v1
# ------------------------------------------------------------
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL_NAME=gpt-3.5-turbo

# ------------------------------------------------------------
# STRIPE (Payments)
# Get these from: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Create a Product + recurring Price in Stripe dashboard, paste Price ID here:
STRIPE_PRICE_ID=price_your-price-id

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production, set to your Railway/custom domain:
# NEXT_PUBLIC_APP_URL=https://gamaliel.yourdomain.com
